{
  "name": "[DabbahWala] Shipday Order Sync",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [{ "field": "hours", "hoursInterval": 2 }]
        }
      },
      "name": "Every 2 Hours",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [200, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://dabbahwala-latest.onrender.com/api/shipday/ingest-orders",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [{ "name": "limit", "value": "200" }]
        },
        "options": { "timeout": 60000 }
      },
      "name": "Ingest Shipday Orders",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [450, 300]
    }
  ],
  "connections": {
    "Every 2 Hours": { "main": [[{ "node": "Ingest Shipday Orders", "type": "main", "index": 0 }]] }
  },
  "active": true,
  "settings": { "executionOrder": "v1" },
  "tags": [{ "name": "dabbahwala" }, { "name": "sync" }]
}
